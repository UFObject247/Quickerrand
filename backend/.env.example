# ErrandBuddy Backend
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/errandbuddy"

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SERVER_SECRET=your_stellar_account_secret_here
ESCROW_CONTRACT_ID=your_deployed_contract_id_here

# Identity (SmileID / Mono)
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# File uploads
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads
