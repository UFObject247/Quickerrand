// This is your Prisma schema file
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RunnerLevel {
  NEWBIE
  VERIFIED
  PRO
}

enum ErrandStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowStatus {
  LOCKED
  FLOAT_RELEASED
  SETTLED
  REFUNDED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(uuid())
  phone          String       @unique
  email          String?      @unique
  passwordHash   String
  displayName    String
  avatarUrl      String?
  isVerified     Boolean      @default(false)
  ninVerifiedAt  DateTime?
  bvnVerifiedAt  DateTime?
  stellarAddress String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  runnerProfile  RunnerProfile?
  errandsPosted  Errand[]     @relation("RequesterErrands")
  errandsRun     Errand[]     @relation("RunnerErrands")

  @@map("users")
}

model RunnerProfile {
  id               String      @id @default(uuid())
  userId           String      @unique
  user             User        @relation(fields: [userId], references: [id])
  level            RunnerLevel @default(NEWBIE)
  qualityRating    Float       @default(5.0)
  completedErrands Int         @default(0)
  currentLat       Float?
  currentLng       Float?
  locationUpdatedAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("runner_profiles")
}

model Errand {
  id              String       @id @default(uuid())
  requesterId     String
  requester       User         @relation("RequesterErrands", fields: [requesterId], references: [id])
  runnerId        String?
  runner          User?        @relation("RunnerErrands", fields: [runnerId], references: [id])
  title           String
  description     String?
  marketLocation  String
  estimatedBudget Decimal      @db.Decimal(12, 2)
  serviceFee      Decimal?     @db.Decimal(12, 2)
  status          ErrandStatus @default(OPEN)
  items           ErrandItem[]
  escrow          Escrow?
  proofPhotos     ProofPhoto[]
  qualityRating   Int?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("errands")
}

model ErrandItem {
  id          String   @id @default(uuid())
  errandId    String
  errand      Errand   @relation(fields: [errandId], references: [id])
  name        String
  quantity    String
  unit        String?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("errand_items")
}

model Escrow {
  id                  String       @id @default(uuid())
  errandId            String       @unique
  errand              Errand       @relation(fields: [errandId], references: [id])
  stellarTxHash       String?
  totalLocked         Decimal      @db.Decimal(12, 2)
  floatReleased       Decimal?     @db.Decimal(12, 2)
  floatReleasedAt     DateTime?
  settlementAmount    Decimal?     @db.Decimal(12, 2)
  settledAt           DateTime?
  status              EscrowStatus @default(LOCKED)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("escrows")
}

model ProofPhoto {
  id         String   @id @default(uuid())
  errandId   String
  errand     Errand   @relation(fields: [errandId], references: [id])
  type       String   // "item_at_stall" | "receipt"
  url        String
  uploadedAt DateTime @default(now())

  @@map("proof_photos")
}

// ─── Community Price Ledger ───────────────────────────────────────────────────

model PriceLedgerEntry {
  id             String   @id @default(uuid())
  itemName       String
  marketId       String
  marketName     String
  pricePaid      Decimal  @db.Decimal(12, 2)
  unit           String   // e.g., "1 bag", "1 kg", "1 bunch"
  runnerId       String
  errandId       String?
  receiptPhotoUrl String?
  timestamp      DateTime @default(now())

  @@index([itemName, marketId, timestamp])
  @@map("price_ledger_entries")
}

model Market {
  id        String   @id @default(uuid())
  name      String   @unique
  state     String
  lga       String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())

  @@map("markets")
}
